# =========================================================================
#  Variables de entorno para RENDER (panel del Web Service -> Environment)
#  Cópialas UNA POR UNA en Render. NO subas este archivo con la contraseña
#  real ni las claves reales: aquí van solo de referencia.
# =========================================================================

# --- App ---
APP_NAME=BoranSac
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:PEGA_AQUI_TU_APP_KEY          # generar con: php artisan key:generate --show
APP_URL=https://TU-BACKEND.onrender.com      # la URL te la da Render al crear el servicio

# --- Auth JWT (tymon/jwt-auth) ---
JWT_SECRET=PEGA_AQUI_TU_JWT_SECRET           # ya te lo generé en el chat

# --- Logs (a la consola de Render) ---
LOG_CHANNEL=stderr
LOG_LEVEL=error

# --- Base de datos: MySQL de Aiven ---
DB_CONNECTION=mysql
DB_HOST=mysql-6fa3800-stray2925-6f84.a.aivencloud.com
DB_PORT=19966
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=PEGA_AQUI_LA_PASSWORD_DE_AIVEN   # revélala en Aiven -> Connection information

# --- Certificado CA de Aiven (ruta DENTRO del contenedor) ---
MYSQL_ATTR_SSL_CA=/var/www/html/certs/ca.pem

# --- Cache / sesiones / colas: modo simple (sin Redis ni BD) ---
CACHE_STORE=file
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
